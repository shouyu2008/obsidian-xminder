{
  "name": "obsidian-xminder",
  "version": "1.0.6",
  "description": "supports functions such as creating, viewing, editing XMind files, and embedding them into Markdown.",
  "main": "main.js",
  "author": {
    "name": "shouyu2008",
    "email": "shouyu_2008@126.com"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='' node esbuild.config.mjs",
    "build": "NODE_OPTIONS='' tsc --noEmit --skipLibCheck && NODE_OPTIONS='' node esbuild.config.mjs production",
    "build:clean": "rm -rf dist && npm run build",
    "typecheck": "NODE_OPTIONS='' tsc --noEmit --skipLibCheck",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "xmind",
    "mind-map"
  ],
  "license": "MIT",
  "dependencies": {
    "jszip": "3.10.1",
    "mind-elixir": "^4.3.3"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@types/jszip": "^3.4.0",
    "@types/node": "^16.11.6",
    "builtin-modules": "3.3.0",
    "esbuild": "0.21.5",
    "eslint": "^10.0.3",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  }
}
